{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@truewatchtech/react-native-mobile": [
        "./packages/react-native-mobile/src/index"
      ],
      "@truewatchtech/react-native-session-replay": [
        "./packages/react-native-session-replay/src/index"
      ]
    },
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "esModuleInterop": true,
    "importsNotUsedAsValues": "error",
    "forceConsistentCasingInFileNames": true,
    "jsx": "react",
    "lib": [
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "node",
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noImplicitUseStrict": false,
    "noStrictGenericChecks": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext"
  },
  "exclude": [
    "example",
    "example-new-architecture",
    "lib",
    "packages/*/lib",
    "packages/**/__tests__",
    "packages/**/__fixtures__",
    "packages/**/__mocks__"
  ]
}
